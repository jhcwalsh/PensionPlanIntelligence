# Copy this file to .env and fill in your values

# Required: Anthropic API key for Claude summarization and RFP extraction
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# RFP pipeline / API config
# Set to "mock" for local dev or CI to read from fixtures/llm_responses
# instead of calling Claude. Leave unset (or any other value) to call the
# real Anthropic API.
LLM_MODE=

# Optional: comma-separated origins for CORS on the FastAPI service
CORS_ORIGIN=*

# Optional: Slack webhook for failed-run alerts. Skipped silently if unset.
SLACK_WEBHOOK_URL=

# Optional override for the eval baseline path used by /api/v1/rfps
# pipeline_health.field_accuracy. Defaults to fixtures/eval_baseline.json.
EVAL_BASELINE_PATH=
