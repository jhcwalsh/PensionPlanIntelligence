# Copy this file to .env and fill in your values

# Required: Anthropic API key for Claude summarization
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ---------------------------------------------------------------------------
# CIO Insights publishing automation (insights/ package)
# ---------------------------------------------------------------------------

# Public base URL the approval magic-links resolve to. The scheduler
# embeds this in emails — must point at the deployed Streamlit app
# so clicks open the approval pages.
APPROVAL_BASE_URL=https://pensionplanintelligence.onrender.com

# Token lifetime in days. After this, tokens auto-expire and clicks
# return an "expired" page rather than acting on the publication.
APPROVAL_TOKEN_TTL_DAYS=7

# Send a reminder email to the founder if a publication has been
# awaiting_approval for this many hours without action.
APPROVAL_REMINDER_HOURS=72

# Where the approval email is sent.
APPROVAL_EMAIL_RECIPIENT=founder@pensionintel.com

# From-address on outgoing approval emails. Must be a domain
# verified in your Resend account.
APPROVAL_EMAIL_FROM=insights@pensionintel.com

# Resend (https://resend.com) — single REST endpoint, no SMTP.
RESEND_API_KEY=

# Slack incoming webhook for failure alerts. Leave blank to disable.
SLACK_WEBHOOK_URL=

# 'live' uses Resend + real Claude calls and pushes to git.
# 'mock' writes emails to tmp/sent_emails/ and returns canned
# Markdown from compose calls — required for the test suite.
INSIGHTS_MODE=live
